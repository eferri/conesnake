{
    "name": "cuda-dev",
    "context": "../gpu",
    "dockerFile": "../gpu/Dockerfile",
    "build": {
        "target": "dev"
    },
    "extensions": [
        "ms-azuretools.vscode-docker",
        "shardulm94.trailing-spaces",
        "streetsidesoftware.code-spell-checker",
        "twxs.cmake",
        "ms-vscode.cpptools",
        "nvidia.nsight-vscode-edition"
    ],
    "overrideCommand": true,
    "workspaceMount": "source=${localWorkspaceFolder}/gpu,target=/app/gpu,type=bind,consistency=cached",
    "workspaceFolder": "/app/gpu",
    "runArgs": [
        "--rm",
        "--env-file",
        ".env"
        // "--network",
        // "baywatchr-api_default"
    ]
}