{
    "search.exclude": {
        ".cargo": true,
        "target*": true,
        "submodules/board": true,
        "submodules/snork": true,
        "gpu/submodules/json": true,
    },
    "files.watcherExclude": {
        ".cargo": true,
        "target*": true
    },
    "editor.formatOnSave": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "debug.allowBreakpointsEverywhere": true,
    "rust-analyzer.completion.autoimport.enable": true,
    "rust-analyzer.debug.engine": "vadimcn.vscode-lldb",
    "rust-analyzer.debug.openDebugPane": true,
    "rust-analyzer.checkOnSave.command": "clippy",
    "rust-analyzer.lens.implementations.enable": false,
    "rust-analyzer.lens.debug.enable": false,
    "rust-analyzer.lens.run.enable": false,
    "lldb.displayFormat": "auto",
    "lldb.showDisassembly": "auto",
    "lldb.dereferencePointers": true,
    "lldb.consoleMode": "commands",
    // For stepping into standard library code
    "lldb.launch.sourceMap": {
        "/rustc/fe5b13d681f25ee6474be29d748c65adcd91f69e": "/home/rust/.rustup/toolchains/stable-x86_64-unknown-linux-gnu/lib/rustlib/src/rust/"
    },
    "cSpell.words": [
        "Backpropagate",
        "playout"
    ],
    "[dockercompose]": {
        "editor.formatOnSave": false
    }
}