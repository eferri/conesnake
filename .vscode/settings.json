{
    "search.exclude": {
        ".cargo": true,
        "target*": true,
        "submodules/board": true,
    },
    "files.watcherExclude": {
        ".cargo": true,
        "target*": true
    },
    "editor.formatOnSave": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "debug.allowBreakpointsEverywhere": true,
    "python.analysis.useLibraryCodeForTypes": false,
    "rust-analyzer.completion.autoimport.enable": true,
    "rust-analyzer.debug.engine": "vadimcn.vscode-lldb",
    "rust-analyzer.debug.openDebugPane": true,
    "rust-analyzer.lens.implementations.enable": false,
    "rust-analyzer.lens.debug.enable": false,
    "rust-analyzer.lens.run.enable": false,
    "lldb.launch.initCommands": [
        "settings set target.disable-aslr false"
    ],
    "lldb.displayFormat": "auto",
    "lldb.showDisassembly": "auto",
    "lldb.dereferencePointers": true,
    "lldb.consoleMode": "commands",
    // For stepping into standard library code
    "lldb.launch.preRunCommands": [
        "script lldb.debugger.HandleCommand('settings set target.source-map /rustc/{} \"{}/lib/rustlib/src/rust\"'.format(os.popen('rustc --version --verbose').read().split('commit-hash: ')[1].split('\\n')[0].strip(), os.popen('rustc --print sysroot').readline().strip()))"
    ],
    "cSpell.words": [
        "Backpropagate",
        "playout"
    ],
    "[yaml]": {
        "editor.formatOnSave": false
    },
    "[dockercompose]": {
        "editor.formatOnSave": false
    },
    "yaml.schemas": {
        "https://json.schemastore.org/github-workflow.json": "file:///app/.github/workflows/deploy.yml",
        "kubernetes://schema/v1%40serviceaccount": [
            "file:///app/k8s/ecr-creds.yml",
            "file:///app/k8s/conesnake/secrets.yaml"
        ]
    }
}