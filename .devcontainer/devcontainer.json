{
    "name": "snake-dev",
    "context": "..",
    "dockerFile": "../Dockerfile",
    "build": {
        "target": "dev"
    },
    "extensions": [
        "tombonnike.vscode-status-bar-format-toggle",
        "shardulm94.trailing-spaces",
        "bungcip.better-toml",
        "vadimcn.vscode-lldb",
        "streetsidesoftware.code-spell-checker",
        "rust-lang.rust-analyzer",
        "golang.go",
        "ms-vscode.cpptools",
        "ms-azuretools.vscode-docker",
        "twxs.cmake",
        "hashicorp.terraform",
        "redhat.vscode-yaml",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "eamodio.gitlens"
    ],
    "overrideCommand": true,
    "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",
    "workspaceFolder": "/app",
    "mounts": [
        "source=${localEnv:HOME}/.kube/config,target=/home/rust/.kube/config,type=bind,consistency=cached"
    ],
    "runArgs": [
        "--rm",
        "--env-file",
        ".env"
        // "--network",
        // "conesnake_default"
    ]
}